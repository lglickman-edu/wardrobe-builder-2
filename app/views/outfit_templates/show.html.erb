<header>
  <h1>
    <%= @the_outfit.name.presence || "Outfit ##{@the_outfit.id}" %>
  </h1>
</header>

<article>
  <% if @the_outfit.notes.present? %>
    <p><%= @the_outfit.notes %></p>
  <% end %>

  <p>
    <strong>Occasion:</strong> <%= @the_outfit.occasion.presence || "—" %><br>
    <strong>Season:</strong> <%= @the_outfit.season.presence || "—" %>
  </p>

  <div class="outfit-items">
    <% @the_outfit.outfit_items.each do |outfit_item| %>
      <% item = @items_by_id[outfit_item.item_id] %>
      <% next if item.nil? %>

      <div class="outfit-item">
        <% if outfit_item.role.present? %>
          <p><strong><%= outfit_item.role.capitalize %></strong></p>
        <% end %>

        <p><%= item.name %></p>

        <% if item.image_url.present? %>
          <img src="<%= item.image_url.url %>" alt="<%= item.name %>" width="250">
        <% else %>
          <p>No image available</p>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
